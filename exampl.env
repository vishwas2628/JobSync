# Server Configuration
PORT=8086
NODE_ENV=development

# Database Configuration (Docker/Local)
# If using the start_local.sh script, the URI will be:
# MONGODB_URI=mongodb://admin:password@localhost:27017/jobsync?authSource=admin
MONGODB_URI=mongodb://localhost:27017/jobsync

# Docker MongoDB Credentials (for docker-compose or start_local.sh)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password

# Security
SESSION_SECRET=your_session_secret_here
JWT_SECRET=your_jwt_secret_here

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_SENDER=your_email@gmail.com

